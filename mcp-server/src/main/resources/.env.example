# MCP Server 环境变量模板
# 复制本文件为 src/main/resources/.env 并填入真实值
# .env 已在 .gitignore 中，不会提交到 Git
# 由 application.yml 中的 spring.config.import 自动加载

# 高德地图 API Key (必需)
# 从 https://console.amap.com 获取
AMAP_API_KEY=your-amap-api-key

# 百度千帆搜索 API Key (必需)
# 从 https://console.bce.baidu.com/qianfan/ 获取
# 格式：bce-v3/ALTAK-xxxxx/xxxxx
BAIDU_API_KEY=your-baidu-api-key

# Tavily 搜索 API Key (可选，百度降级后备)
# 从 https://app.tavily.com 获取
# TAVILY_API_KEY=your-tavily-api-key
